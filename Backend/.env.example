# ============================================
# AntiGravity (ResFlow) — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/resflow

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Google Gemini
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash
MAX_TOKENS=8192

# OpenAI (Embeddings — for RAG pipeline)
# OPENAI_API_KEY=sk-...

# Cohere (Reranking — for RAG pipeline)
# COHERE_API_KEY=...

# Supabase (pgvector for RAG)
# SUPABASE_URL=https://...
# SUPABASE_SERVICE_ROLE_KEY=...

# AWS S3 (Resume file storage)
# AWS_S3_BUCKET=antigravity-resumes
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Job Search APIs
# ADZUNA_APP_ID=...
# ADZUNA_APP_KEY=...
# INDEED_PUBLISHER_ID=...
# LINKEDIN_CLIENT_ID=...
# LINKEDIN_CLIENT_SECRET=...

# Feature Flags
ENABLE_LIVE_JOBS=false
ENABLE_COVER_LETTER=true
ENABLE_RAG=false
MAX_QUESTIONS_PER_SESSION=6
MAX_RESUME_SIZE_MB=10

# System Prompt Version
SYSTEM_PROMPT_VERSION=v2.1
